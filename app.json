{
  "expo": {
    "name": "BALURE",
    "slug": "balure-app",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "balure",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0b1f33"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.balure.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "BALURE uses your location to fetch local weather, water and tide conditions for fishing recommendations."
      }
    },
    "android": {
      "package": "com.balure.app",
      "adaptiveIcon": {
        "backgroundColor": "#0b1f33"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "BALURE uses your location to fetch local weather, water and tide conditions for fishing recommendations."
        }
      ]
    ]
  }
}
