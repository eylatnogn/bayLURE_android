{
  "expo": {
    "name": "bayLURE",
    "slug": "baylure",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "baylure",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.baylure.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.baylure.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1e4a3c"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "blockedPermissions": ["android.permission.RECORD_AUDIO"]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-2923543385163788~3293892067"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "bayLURE uses your location to fetch local weather, water and tide conditions for fishing recommendations."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "bayLURE lets you attach a photo of your catch to your log.",
          "microphonePermission": false,
          "cameraPermission": false
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#1e4a3c",
          "dark": {
            "backgroundColor": "#0f1713"
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "70318c07-bf6e-4b59-8ec2-ef141de30f09"
      }
    },
    "owner": "eylatnogn",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/70318c07-bf6e-4b59-8ec2-ef141de30f09"
    }
  }
}
