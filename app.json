{
  "expo": {
    "name": "bayLURE",
    "slug": "baylure",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "baylure",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.baylure.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.baylure.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1e4a3c"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "bayLURE uses your location to fetch local weather, water and tide conditions for fishing recommendations."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "bayLURE lets you attach a photo of your catch to your log."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#1e4a3c",
          "dark": {
            "backgroundColor": "#0f1713"
          }
        }
      ]
    ]
  }
}
